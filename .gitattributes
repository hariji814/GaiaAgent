# Normalize line endings to LF and declare binary assets.
# Source is UTF-8 only — the pre-commit encoding hook rejects non-UTF-8 / CRLF.
# This addresses the historical Chinese-comment mojibake recurrence (TODO P1).

* text=auto eol=lf

# Source & docs — always LF
*.py     text eol=lf
*.md     text eol=lf
*.toml   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.json   text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
*.txt    text eol=lf
*.sh     text eol=lf
Makefile text eol=lf

# Binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary
*.lock binary
